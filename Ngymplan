    <p class="rest-label">Rest between exercises</p>
    <div class="rest-options">
      <div class="rest-opt selected" data-seconds="30" onclick="selectRest(this)">
        <div class="ro-time">0:30</div>
        <div class="ro-label">Short</div>
      </div>
      <div class="rest-opt" data-seconds="60" onclick="selectRest(this)">
        <div class="ro-time">1:00</div>
        <div class="ro-label">Standard</div>
      </div>
      <div class="rest-opt" data-seconds="90" onclick="selectRest(this)">
        <div class="ro-time">1:30</div>
        <div class="ro-label">Long</div>
      </div>
      <div class="rest-opt" data-seconds="120" onclick="selectRest(this)">
        <div class="ro-time">2:00</div>
        <div class="ro-label">Recovery</div>
      </div>
      <div class="rest-opt" data-seconds="180" onclick="selectRest(this)">
        <div class="ro-time">3:00</div>
        <div class="ro-label">Heavy</div>
      </div>
      <div class="rest-opt" data-seconds="0" onclick="selectRest(this)">
        <div class="ro-time">Off</div>
        <div class="ro-label">No rest</div>
      </div>
    </div>
    <div class="custom-rest">
      <input type="number" id="custom-rest-input" placeholder="Custom seconds..." min="0" max="600" oninput="setCustomRest(this.value)">
      <label>sec</label>
    </div>
    <button class="start-btn" onclick="startWorkout()">Start Workout →</button>
  </div>
</div>

<!-- WORKOUT VIEW -->
<div id="workout-view" class="screen">
  <div class="workout-header">
    <div class="workout-header-top">
      <button class="back-btn" onclick="showWeek()">‹</button>
      <div class="workout-title">
        <div class="wt-week" id="wv-week-label"></div>
        <div class="wt-name" id="wv-name"></div>
      </div>
      <div class="nav-spacer"></div>
    </div>
    <div class="progress-bar-wrap"><div class="progress-bar-fill" id="progress-fill" style="width:0%"></div></div>
  </div>
  <div class="workout-body" id="workout-body"></div>
</div>

<!-- DONE SCREEN -->
<div id="done-screen" class="screen">
  <div class="done-icon">🏆</div>
  <h2>Workout Complete!</h2>
  <p>Amazing work. You crushed it.<br>Rest up and come back stronger.</p>
  <button class="done-btn" onclick="showHome()">Back to Plan</button>
</div>

<!-- REST OVERLAY -->
<div id="rest-overlay">
  <div class="rest-modal">
    <h3>Rest Time</h3>
    <p class="rest-sub" id="rest-next-label">Next up: —</p>
    <div class="rest-circle">
      <svg width="140" height="140" viewBox="0 0 140 140">
        <circle cx="70" cy="70" r="60" fill="none" stroke="#e8d8d0" stroke-width="8"/>
        <circle cx="70" cy="70" r="60" fill="none" stroke="#b08a7a" stroke-width="8"
          stroke-dasharray="377" id="rest-ring" stroke-linecap="round"/>
      </svg>
      <div class="rest-countdown" id="rest-countdown">60</div>
    </div>
    <div class="rest-actions">
      <button class="rest-skip" onclick="skipRest()">Skip</button>
      <button class="rest-add" onclick="addRestTime(15)">+15s</button>
    </div>
  </div>
</div>

