  .home-header { background: var(--accent); padding: 60px 24px 40px; text-align: center; }
  .home-header h1 { font-size: 28px; font-weight: 700; color: white; letter-spacing: -0.5px; }
  .home-header p { color: rgba(255,255,255,0.85); font-size: 15px; margin-top: 6px; }
  .week-grid { padding: 24px 16px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
  .week-btn { background: var(--surface); border: 1.5px solid var(--border); border-radius: 12px; padding: 14px 6px; text-align: center; cursor: pointer; transition: all 0.15s; }
  .week-btn:active { transform: scale(0.96); background: var(--accent-light); }
  .week-btn .wnum { font-size: 18px; font-weight: 700; color: var(--accent-dark); }
  .week-btn .wlabel { font-size: 11px; color: var(--text-muted); margin-top: 2px; }

  /* WEEK VIEW */
  #week-view { background: var(--bg); }
  .nav-bar { display: flex; align-items: center; padding: 56px 16px 16px; background: var(--surface); border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 10; }
  .back-btn { width: 36px; height: 36px; border: none; background: var(--surface2); border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
  .nav-title { flex: 1; text-align: center; font-size: 17px; font-weight: 600; }
  .nav-spacer { width: 36px; }
  .workout-cards { padding: 20px 16px; display: flex; flex-direction: column; gap: 12px; }
  .workout-card { background: var(--surface); border-radius: var(--radius); border: 1.5px solid var(--border); padding: 20px; cursor: pointer; transition: all 0.15s; box-shadow: var(--shadow); }
  .workout-card:active { transform: scale(0.98); }
  .workout-card .wc-tag { font-size: 11px; font-weight: 600; letter-spacing: 0.8px; text-transform: uppercase; color: var(--accent); margin-bottom: 6px; }
  .workout-card h3 { font-size: 20px; font-weight: 700; color: var(--text); }
  .workout-card .wc-meta { font-size: 13px; color: var(--text-muted); margin-top: 4px; }
  .workout-card .wc-arrow { float: right; color: var(--accent); font-size: 20px; margin-top: -2px; }

  /* SESSION SETUP */
  #session-setup { background: var(--bg); }
  .setup-content { padding: 24px 20px; flex: 1; }
  .setup-content h2 { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
  .setup-content .setup-sub { color: var(--text-muted); font-size: 14px; margin-bottom: 32px; }
  .rest-label { font-size: 15px; font-weight: 600; margin-bottom: 16px; }
  .rest-options { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 12px; }
  .rest-opt { background: var(--surface); border: 2px solid var(--border); border-radius: 12px; padding: 16px 8px; text-align: center; cursor: pointer; transition: all 0.15s; }
  .rest-opt.selected { border-color: var(--accent); background: var(--accent-light); }
  .rest-opt .ro-time { font-size: 20px; font-weight: 700; color: var(--accent-dark); }
  .rest-opt .ro-label { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
  .custom-rest { margin-top: 8px; display: flex; align-items: center; gap: 12px; }
  .custom-rest input { flex: 1; border: 2px solid var(--border); border-radius: 10px; padding: 12px 14px; font-size: 16px; background: var(--surface); color: var(--text); outline: none; }
  .custom-rest input:focus { border-color: var(--accent); }
  .custom-rest label { font-size: 14px; color: var(--text-muted); }
  .start-btn { width: 100%; background: var(--accent); color: white; border: none; border-radius: 14px; padding: 18px; font-size: 17px; font-weight: 700; cursor: pointer; margin-top: 32px; letter-spacing: 0.3px; }
  .start-btn:active { background: var(--accent-dark); }

  /* WORKOUT VIEW */
  #workout-view { background: var(--bg); }
  .workout-header { background: var(--surface); border-bottom: 1px solid var(--border); padding: 56px 16px 16px; position: sticky; top: 0; z-index: 10; }
  .workout-header-top { display: flex; align-items: center; margin-bottom: 12px; }
  .workout-title { flex: 1; text-align: center; }
  .workout-title .wt-week { font-size: 12px; color: var(--text-muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.6px; }
  .workout-title .wt-name { font-size: 18px; font-weight: 700; }
  .progress-bar-wrap { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
  .progress-bar-fill { height: 100%; background: var(--accent); border-radius: 2px; transition: width 0.4s ease; }
  .workout-body { padding: 16px; display: flex; flex-direction: column; gap: 16px; }

  /* CIRCUIT BLOCK */
  .circuit-block { background: var(--surface); border-radius: var(--radius); overflow: hidden; box-shadow: var(--shadow); }
  .circuit-header { padding: 14px 18px; display: flex; align-items: center; gap: 10px; }
  .circuit-header.c1 { background: var(--circuit1); }
  .circuit-header.c2 { background: var(--circuit2); }
  .circuit-header.core { background: var(--core); }
  .circuit-header h3 { font-size: 16px; font-weight: 700; color: white; flex: 1; }
  .circuit-header .repeat-badge { background: rgba(255,255,255,0.3); color: white; font-size: 12px; font-weight: 600; border-radius: 20px; padding: 4px 10px; }
  .exercise-list { }
  .exercise-item { padding: 14px 18px; border-bottom: 1px solid var(--border); cursor: pointer; transition: background 0.1s; }
  .exercise-item:last-child { border-bottom: none; }
  .exercise-item:active { background: var(--surface2); }
  .ex-row { display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; }
  .ex-name { font-size: 15px; font-weight: 600; flex: 1; line-height: 1.3; }
  .ex-reps { font-size: 13px; color: var(--accent-dark); font-weight: 600; white-space: nowrap; }
  .ex-tip { font-size: 13px; color: var(--text-muted); line-height: 1.5; margin-top: 8px; padding-top: 8px; border-top: 1px solid var(--border); display: none; }
  .ex-tip.open { display: block; }
  .tip-toggle { font-size: 11px; color: var(--accent); font-weight: 600; margin-top: 6px; display: inline-block; }

  /* REST TIMER */
  #rest-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); z-index: 100; align-items: center; justify-content: center; }
  #rest-overlay.active { display: flex; }
  .rest-modal { background: var(--surface); border-radius: 24px; padding: 40px 32px; text-align: center; width: 90%; max-width: 340px; }
  .rest-modal h3 { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
  .rest-modal .rest-sub { font-size: 14px; color: var(--text-muted); margin-bottom: 28px; }
  .rest-circle { width: 140px; height: 140px; border-radius: 50%; background: var(--accent-light); display: flex; align-items: center; justify-content: center; margin: 0 auto 28px; position: relative; }
  .rest-circle svg { position: absolute; top: 0; left: 0; transform: rotate(-90deg); }
  .rest-circle .rest-countdown { font-size: 48px; font-weight: 700; color: var(--accent-dark); z-index: 1; }
  .rest-actions { display: flex; gap: 10px; }
  .rest-skip { flex: 1; background: var(--surface2); border: none; border-radius: 12px; padding: 14px; font-size: 15px; font-weight: 600; color: var(--text-muted); cursor: pointer; }
  .rest-add { background: var(--accent-light); border: none; border-radius: 12px; padding: 14px 16px; font-size: 15px; font-weight: 600; color: var(--accent-dark); cursor: pointer; }

  /* DONE SCREEN */
  #done-screen { background: var(--bg); align-items: center; justify-content: center; text-align: center; padding: 40px 24px; }
  .done-icon { font-size: 72px; margin-bottom: 20px; }
  .done-screen h2 { font-size: 28px; font-weight: 700; margin-bottom: 10px; }
  .done-screen p { font-size: 16px; color: var(--text-muted); margin-bottom: 40px; line-height: 1.6; }
  .done-btn { background: var(--accent); color: white; border: none; border-radius: 14px; padding: 16px 40px; font-size: 17px; font-weight: 700; cursor: pointer; }
</style>
</head>
