    --accent: #b08a7a;
    --accent-light: #e8d8d0;
    --accent-dark: #8a6a5c;
    --text: #2a2218;
    --text-muted: #8a7e74;
    --border: #e8e0d8;
    --circuit1: #d4a89a;
    --circuit2: #9ab4c8;
    --core: #b8c9a0;
    --radius: 16px;
